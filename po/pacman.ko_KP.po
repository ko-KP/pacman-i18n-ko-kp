"\n"
"use '%s {-h --help}' with an operation for available options\n"
msgstr ""
"\n"
"리용가능한 선택항목을 보려면 조작과 함께 '%s {-h --help}'를 리용하십시오\n"

#: src/pacman/pacman.c:125
#, c-format
msgid "  -c, --cascade        remove packages and all packages that depend on them\n"
msgstr "  -c, --cascade        패키지들과 그에 의존하는 모든 패키지들을 삭제\n"

#: src/pacman/pacman.c:126
#, c-format
msgid "  -n, --nosave         remove configuration files\n"
msgstr "  -n, --nosave         설정화일들을 삭제\n"

#: src/pacman/pacman.c:127
#, c-format
msgid ""
"  -s, --recursive      remove unnecessary dependencies\n"
"                       (-ss includes explicitly installed dependencies)\n"
msgstr ""
"  -s, --recursive      불필요한 의존성들을 삭제\n"
"                       (-ss는 명시적으로 설치된 의존성들도 포함)\n"

#: src/pacman/pacman.c:129
#, c-format
msgid "  -u, --unneeded       remove unneeded packages\n"
msgstr "  -u, --unneeded       불필요한 패키지들을 삭제\n"

#: src/pacman/pacman.c:132 src/pacman/pacman.c:166
#, c-format
msgid "      --needed         do not reinstall up to date packages\n"
msgstr "      --needed         최신판본의 패키지들은 재설치하지 않음\n"

#: src/pacman/pacman.c:137
#, c-format
msgid "  -c, --changelog      view the changelog of a package\n"
msgstr "  -c, --changelog      패키지의 변경기록을 현시\n"

#: src/pacman/pacman.c:138
#, c-format
msgid "  -d, --deps           list packages installed as dependencies [filter]\n"
msgstr "  -d, --deps           의존성으로 설치된 패키지목록 현시 [려과기]\n"

#: src/pacman/pacman.c:139
#, c-format
msgid "  -e, --explicit       list packages explicitly installed [filter]\n"
msgstr "  -e, --explicit       명시적으로 설치된 패키지목록 현시 [려과기]\n"

#: src/pacman/pacman.c:140
#, c-format
msgid "  -g, --groups         view all members of a package group\n"
msgstr "  -g, --groups         패키지집단의 모든 성원들을 현시\n"

#: src/pacman/pacman.c:141
#, c-format
msgid "  -i, --info           view package information (-ii for backup files)\n"
msgstr "  -i, --info           패키지정보 현시 (-ii는 여벌화일 포함)\n"

#: src/pacman/pacman.c:142
#, c-format
msgid "  -k, --check          check that package files exist (-kk for file properties)\n"
msgstr "  -k, --check          패키지화일의 존재여부 검사 (-kk는 화일속성 검사)\n"

#: src/pacman/pacman.c:143 src/pacman/pacman.c:180
#, c-format
msgid "  -l, --list           list the files owned by the queried package\n"
msgstr "  -l, --list           조회된 패키지에 속한 화일목록을 현시\n"

#: src/pacman/pacman.c:144
#, c-format
msgid "  -m, --foreign        list installed packages not found in sync db(s) [filter]\n"
msgstr "  -m, --foreign        동기화된 자료기지에 없는 설치된 패키지목록 현시 [려과기]\n"

#: src/pacman/pacman.c:145
#, c-format
msgid "  -n, --native         list installed packages only found in sync db(s) [filter]\n"
msgstr "  -n, --native         동기화된 자료기지에 있는 설치된 패키지목록 현시 [려과기]\n"

#: src/pacman/pacman.c:146
#, c-format
msgid "  -o, --owns <file>    query the package that owns <file>\n"
msgstr "  -o, --owns <화일>    <화일>을 소유한 패키지를 조회\n"

#: src/pacman/pacman.c:147
#, c-format
msgid "  -p, --file <package> query a package file instead of the database\n"
msgstr "  -p, --file <패키지>  자료기지대신 패키지화일을 조회\n"

#: src/pacman/pacman.c:148 src/pacman/pacman.c:161 src/pacman/pacman.c:181
#, c-format
msgid "  -q, --quiet          show less information for query and search\n"
msgstr "  -q, --quiet          조회와 검색결과를 간략하게 현시\n"

#: src/pacman/pacman.c:149
#, c-format
msgid "  -s, --search <regex> search locally-installed packages for matching strings\n"
msgstr "  -s, --search <정규표현식> 문자렬과 일치하는 국부설치된 패키지 검색\n"

#: src/pacman/pacman.c:150
#, c-format
msgid ""
"  -t, --unrequired     list packages not (optionally) required by any\n"
"                       package (-tt to ignore optdepends) [filter]\n"
msgstr ""
"  -t, --unrequired     아무 패키지에서도 요구하지 않는 패키지목록 현시\n"
"                       (-tt는 선택적 의존성 무시) [려과기]\n"

#: src/pacman/pacman.c:152
#, c-format
msgid "  -u, --upgrades       list outdated packages [filter]\n"
msgstr "  -u, --upgrades       오래된 패키지목록 현시 [려과기]\n"

#: src/pacman/pacman.c:156
#, c-format
msgid "  -c, --clean          remove old packages from cache directory (-cc for all)\n"
msgstr "  -c, --clean          고속완충기억등록부에서 옛 패키지 삭제 (-cc는 전부 삭제)\n"

#: src/pacman/pacman.c:157
#, c-format
msgid ""
"  -g, --groups         view all members of a package group\n"
"                       (-gg to view all groups and members)\n"
msgstr ""
"  -g, --groups         패키지집단의 모든 성원 현시\n"
"                       (-gg는 모든 집단과 성원 현시)\n"

#: src/pacman/pacman.c:159
#, c-format
msgid "  -i, --info           view package information (-ii for extended information)\n"
msgstr "  -i, --info           패키지정보 현시 (-ii는 상세정보 현시)\n"

#: src/pacman/pacman.c:160
#, c-format
msgid "  -l, --list <repo>    view a list of packages in a repo\n"
msgstr "  -l, --list <저장소>  저장소안의 패키지목록 현시\n"

#: src/pacman/pacman.c:162
#, c-format
msgid "  -s, --search <regex> search remote repositories for matching strings\n"
msgstr "  -s, --search <정규표현식> 원격저장소에서 일치하는 문자렬 검색\n"

#: src/pacman/pacman.c:163
#, c-format
msgid "  -u, --sysupgrade     upgrade installed packages (-uu enables downgrades)\n"
msgstr "  -u, --sysupgrade     설치된 패키지 갱신 (-uu는 판본낮추기 허용)\n"

#: src/pacman/pacman.c:164 src/pacman/pacman.c:183
#, c-format
msgid ""
"  -y, --refresh        download fresh package databases from the server\n"
"                       (-yy to force a refresh even if up to date)\n"
msgstr ""
"  -y, --refresh        봉사기로부터 새 패키지자료기지 내리적재\n"
"                       (-yy는 최신판이여도 강제로 갱신)\n"

#: src/pacman/pacman.c:170
#, c-format
msgid "      --asdeps         mark packages as non-explicitly installed\n"
msgstr "      --asdeps         패키지를 비명시적으로 설치된것으로 표식\n"

#: src/pacman/pacman.c:171
#, c-format
msgid "      --asexplicit     mark packages as explicitly installed\n"
msgstr "      --asexplicit     패키지를 명시적으로 설치된것으로 표식\n"

#: src/pacman/pacman.c:172
#, c-format
msgid "  -k, --check          test local database for validity (-kk for sync databases)\n"
msgstr "  -k, --check          국부자료기지의 유효성 검사 (-kk는 동기화자료기지)\n"

#: src/pacman/pacman.c:173
#, c-format
msgid "  -q, --quiet          suppress output of success messages\n"
msgstr "  -q, --quiet          성공통보문의 출력을 억제\n"

#: src/pacman/pacman.c:182
#, c-format
msgid "  -x, --regex          enable searching using regular expressions\n"
msgstr "  -x, --regex          정규표현식을 리용한 검색 허용\n"

#: src/pacman/pacman.c:185
#, c-format
msgid ""
"      --machinereadable\n"
"                       produce machine-readable output\n"
msgstr ""
"      --machinereadable\n"
"                       기계가 판독할수 있는 출력물 생성\n"

#: src/pacman/pacman.c:191
#, c-format
msgid "  -w, --downloadonly   download packages but do not install/upgrade anything\n"
msgstr "  -w, --downloadonly   패키지를 내리적재하기만 하고 설치/갱신은 하지 않음\n"

#: src/pacman/pacman.c:192
#, c-format
msgid ""
"      --overwrite <glob>\n"
"                       overwrite conflicting files (can be used more than once)\n"
msgstr ""
"      --overwrite <전역>\n"
"                       충돌하는 화일 덧쓰기 (여러번 사용할수 있음)\n"

#: src/pacman/pacman.c:194
#, c-format
msgid "      --asdeps         install packages as non-explicitly installed\n"
msgstr "      --asdeps         패키지를 비명시적으로 설치된것으로 취급하여 설치\n"

#: src/pacman/pacman.c:195
#, c-format
msgid "      --asexplicit     install packages as explicitly installed\n"
msgstr "      --asexplicit     패키지를 명시적으로 설치된것으로 취급하여 설치\n"

#: src/pacman/pacman.c:196
#, c-format
msgid "      --ignore <pkg>   ignore a package upgrade (can be used more than once)\n"
msgstr "      --ignore <패키지> 패키지갱신 무시 (여러번 사용할수 있음)\n"

#: src/pacman/pacman.c:197
#, c-format
msgid ""
"      --ignoregroup <grp>\n"
"                       ignore a group upgrade (can be used more than once)\n"
msgstr ""
"      --ignoregroup <집단>\n"
"                       집단갱신 무시 (여러번 사용할수 있음)\n"

#: src/pacman/pacman.c:201
#, c-format
msgid "  -d, --nodeps         skip dependency version checks (-dd to skip all checks)\n"
msgstr "  -d, --nodeps         의존성판본검사 생략 (-dd는 모든 검사 생략)\n"

#: src/pacman/pacman.c:202
#, c-format
msgid ""
"      --assume-installed <package=version>\n"
"                       add a virtual package to satisfy dependencies\n"
msgstr ""
"      --assume-installed <패키지=판본>\n"
"                       의존성을 만족시키기 위한 가상패키지 추가\n"

#: src/pacman/pacman.c:204
#, c-format
msgid "      --dbonly         only modify database entries, not package files\n"
msgstr "      --dbonly         패키지화일은 놔두고 자료기지항목만 수정\n"

#: src/pacman/pacman.c:205
#, c-format
msgid "      --noprogressbar  do not show a progress bar when downloading files\n"
msgstr "      --noprogressbar  화일을 내리적재할 때 진행상태를 현시하지 않음\n"

#: src/pacman/pacman.c:206
#, c-format
msgid "      --noscriptlet    do not execute the install scriptlet if one exists\n"
msgstr "      --noscriptlet    설치스크립트가 있어도 실행하지 않음\n"

#: src/pacman/pacman.c:207
#, c-format
msgid "  -p, --print          print the targets instead of performing the operation\n"
msgstr "  -p, --print          조작을 수행하는 대신 대상들을 출력함\n"

#: src/pacman/pacman.c:208
#, c-format
msgid ""
"      --print-format <string>\n"
"                       specify how the targets should be printed\n"
msgstr ""
"      --print-format <문자렬>\n"
"                       대상을 출력할 형식을 지정\n"

#: src/pacman/pacman.c:213
#, c-format
msgid "  -b, --dbpath <path>  set an alternate database location\n"
msgstr "  -b, --dbpath <경로>  다른 자료기지위치를 설정\n"

#: src/pacman/pacman.c:214
#, c-format
msgid "  -r, --root <path>    set an alternate installation root\n"
msgstr "  -r, --root <경로>    다른 설치뿌리를 설정\n"

#: src/pacman/pacman.c:215
#, c-format
msgid "  -v, --verbose        be verbose\n"
msgstr "  -v, --verbose        상세정보 현시\n"

#: src/pacman/pacman.c:216
#, c-format
msgid "      --arch <arch>    set an alternate architecture\n"
msgstr "      --arch <체계구조> 다른 체계구조를 설정\n"

#: src/pacman/pacman.c:217
#, c-format
msgid "      --sysroot        operate on a mounted guest system (root-only)\n"
msgstr "      --sysroot        탑재된 손님체계우에서 조작 (뿌리전용)\n"

#: src/pacman/pacman.c:218
#, c-format
msgid "      --cachedir <dir> set an alternate package cache location\n"
msgstr "      --cachedir <등록부> 다른 패키지고속완충기억기위치를 설정\n"

#: src/pacman/pacman.c:219
#, c-format
msgid "      --hookdir <dir>  set an alternate hook location\n"
msgstr "      --hookdir <등록부> 다른 후크위치를 설정\n"

#: src/pacman/pacman.c:220
#, c-format
msgid "      --color <when>   colorize the output\n"
msgstr "      --color <조건>   출력을 다색으로 현시\n"

#: src/pacman/pacman.c:221
#, c-format
msgid "      --config <path>  set an alternate configuration file\n"
msgstr "      --config <경로>  다른 설정화일을 설정\n"

#: src/pacman/pacman.c:222
#, c-format
msgid "      --debug          display debug messages\n"
msgstr "      --debug          오유수정통보문을 현시\n"

#: src/pacman/pacman.c:223
#, c-format
msgid "      --gpgdir <path>  set an alternate home directory for GnuPG\n"
msgstr "      --gpgdir <경로>  GnuPG를 위한 다른 기초등록부를 설정\n"

#: src/pacman/pacman.c:224
#, c-format
msgid "      --logfile <path> set an alternate log file\n"
msgstr "      --logfile <경로> 다른 기록화일을 설정\n"

#: src/pacman/pacman.c:225
#, c-format
msgid "      --noconfirm      do not ask for any confirmation\n"
msgstr "      --noconfirm      아무런 확인도 요구하지 않음\n"

#: src/pacman/pacman.c:226
#, c-format
msgid "      --confirm        always ask for confirmation\n"
msgstr "      --confirm        언제나 확인을 요구함\n"

#: src/pacman/pacman.c:227
#, c-format
msgid ""
"      --disable-download-timeout\n"
"                       use relaxed timeouts for download\n"
msgstr ""
"      --disable-download-timeout\n"
"                       내리적재시간초과제한을 해제\n"

#: src/pacman/pacman.c:229
#, c-format
msgid ""
"      --disable-sandbox\n"
"                       disables all sandbox features used for the downloader process\n"
msgstr ""
"      --disable-sandbox\n"
"                       내리적재공정에서 사용되는 모든 모래함기능을 비활성화\n"

#: src/pacman/pacman.c:231
#, c-format
msgid ""
"      --disable-sandbox-filesystem\n"
"                       disables the filesystem part of the downloader process sandbox\n"
msgstr ""
"      --disable-sandbox-filesystem\n"
