#: scripts/makepkg.sh.in:631
msgid "Failed to create package file."
msgstr "패키지화일 생성 실패."

#: scripts/makepkg.sh.in:667
msgid "Creating source package..."
msgstr "원천패키지 생성하는중..."

#: scripts/makepkg.sh.in:673 scripts/makepkg.sh.in:686
#, sh-printf-format
msgid "Adding %s..."
msgstr "%s 추가하는중..."

#: scripts/makepkg.sh.in:707
#, sh-printf-format
msgid "Adding %s file (%s)..."
msgstr "%s 화일 (%s) 추가하는중..."

#: scripts/makepkg.sh.in:728
msgid "Compressing source package..."
msgstr "원천패키지 압축하는중..."

#: scripts/makepkg.sh.in:739
msgid "Failed to create source package file."
msgstr "원천패키지화일 생성 실패."

#: scripts/makepkg.sh.in:754
#, sh-printf-format
msgid "Installing package %s with %s..."
msgstr "%s 패키지를 %s(으)로 설치하는중..."

#: scripts/makepkg.sh.in:756
#, sh-printf-format
msgid "Installing %s package group with %s..."
msgstr "%s 패키지집단을 %s(으)로 설치하는중..."

#: scripts/makepkg.sh.in:777
msgid "Failed to install built package(s)."
msgstr "구축된 패키지들을 설치하는데 실패하였습니다."

#: scripts/makepkg.sh.in:790
msgid "A package has already been built, installing existing package..."
msgstr "패키지가 이미 구축되였습니다, 기존 패키지를 설치하는중..."

#: scripts/makepkg.sh.in:794
#, sh-printf-format
msgid "A package has already been built. (use %s to overwrite)"
msgstr "패키지가 이미 구축되였습니다. (덧쓰려면 %s를 리용하십시오)"

#: scripts/makepkg.sh.in:816
msgid "The package group has already been built, installing existing packages..."
msgstr "패키지집단이 이미 구축되였습니다, 기존 패키지들을 설치하는중..."

#: scripts/makepkg.sh.in:820
#, sh-printf-format
msgid "The package group has already been built. (use %s to overwrite)"
msgstr "패키지집단이 이미 구축되였습니다. (덧쓰려면 %s를 리용하십시오)"

#: scripts/makepkg.sh.in:825
#, sh-printf-format
msgid "Part of the package group has already been built. (use %s to overwrite)"
msgstr "패키지집단의 일부가 이미 구축되였습니다. (덧쓰려면 %s를 리용하십시오)"

#: scripts/makepkg.sh.in:883
msgid "Make packages compatible for use with pacman"
msgstr "패키지들을 pacman과 호환되게 리용할수 있도록 만듭니다"

#: scripts/makepkg.sh.in:885 scripts/pacman-db-upgrade.sh.in:41
#, sh-printf-format
msgid "Usage: %s [options]"
msgstr "사용법: %s [선택항목]"

#: scripts/makepkg.sh.in:887 scripts/pacman-key.sh.in:82
msgid "Options:"
msgstr "선택항목:"

#: scripts/makepkg.sh.in:888
#, sh-printf-format
msgid "  -A, --ignorearch Ignore incomplete %s field in %s"
msgstr "  -A, --ignorearch %2$s의 불완전한 %1$s 마당을 무시"

#: scripts/makepkg.sh.in:889
msgid "  -c, --clean      Clean up work files after build"
msgstr "  -c, --clean      구축후 작업화일들 정리"

#: scripts/makepkg.sh.in:890
#, sh-printf-format
msgid "  -C, --cleanbuild Remove %s dir before building the package"
msgstr "  -C, --cleanbuild 패키지를 구축하기전에 %s 등록부 삭제"

#: scripts/makepkg.sh.in:891
msgid "  -d, --nodeps     Skip all dependency checks"
msgstr "  -d, --nodeps     모든 의존성검사를 뛰여넘음"

#: scripts/makepkg.sh.in:892
msgid "  -D, --dir <dir>  Change to directory <dir> before processing PKGBUILD"
msgstr "  -D, --dir <등록부>  PKGBUILD를 처리하기전에 <등록부>로 이동"

#: scripts/makepkg.sh.in:893
#, sh-printf-format
msgid "  -e, --noextract  Do not extract source files (use existing %s dir)"
msgstr "  -e, --noextract  원천화일들을 추출하지 않음 (기존 %s 등록부 리용)"

#: scripts/makepkg.sh.in:894
msgid "  -f, --force      Overwrite existing package"
msgstr "  -f, --force      기존 패키지 덧쓰기"

#: scripts/makepkg.sh.in:895
msgid "  -g, --geninteg   Generate integrity checks for source files"
msgstr "  -g, --geninteg   원천화일들에 대한 완전성검사 생성"

#: scripts/makepkg.sh.in:896
msgid "  -h, --help       Show this help message and exit"
msgstr "  -h, --help       이 도움말통보문을 보이고 종료"

#: scripts/makepkg.sh.in:897
msgid "  -i, --install    Install package after successful build"
msgstr "  -i, --install    구축성공후 패키지 설치"

#: scripts/makepkg.sh.in:898
msgid "  -L, --log        Log package build process"
msgstr "  -L, --log        패키지구축공정 기록"

#: scripts/makepkg.sh.in:899
msgid "  -m, --nocolor    Disable colorized output messages"
msgstr "  -m, --nocolor    다색출력통보문 비활성화"

#: scripts/makepkg.sh.in:900
msgid "  -o, --nobuild    Download and extract files only"
msgstr "  -o, --nobuild    화일들을 내리적재하고 추출하기만 함"

#: scripts/makepkg.sh.in:901
#, sh-printf-format
msgid "  -p <file>        Use an alternate build script (instead of '%s')"
msgstr "  -p <화일>        ('%s' 대신) 다른 구축스크립트 리용"

#: scripts/makepkg.sh.in:902
msgid "  -r, --rmdeps     Remove installed dependencies after a successful build"
msgstr "  -r, --rmdeps     구축성공후 설치된 의존성들 삭제"

#: scripts/makepkg.sh.in:903
msgid "  -R, --repackage  Repackage contents of the package without rebuilding"
msgstr "  -R, --repackage  재구축없이 패키지내용물 재포장"

#: scripts/makepkg.sh.in:904
#, sh-printf-format
msgid "  -s, --syncdeps   Install missing dependencies with %s"
msgstr "  -s, --syncdeps   %s(으)로 빠진 의존성들 설치"

#: scripts/makepkg.sh.in:905
msgid "  -S, --source     Generate a source-only tarball without downloaded sources"
msgstr "  -S, --source     내리적재한 원천화일없이 원천전용 타르문서고 생성"

#: scripts/makepkg.sh.in:906
msgid "  -V, --version    Show version information and exit"
msgstr "  -V, --version    판본정보를 보이고 종료"

#: scripts/makepkg.sh.in:907
msgid "  --allsource      Generate a source-only tarball including downloaded sources"
msgstr "  --allsource      내리적재한 원천화일들을 포함하여 원천전용 타르문서고 생성"

#: scripts/makepkg.sh.in:908
#, sh-printf-format
msgid "  --check          Run the %s function in the %s"
msgstr "  --check          %2$s안의 %1$s 함수 실행"

#: scripts/makepkg.sh.in:909
#, sh-printf-format
msgid "  --config <file>  Use an alternate config file (instead of '%s')"
msgstr "  --config <화일>  ('%s' 대신) 다른 설정화일 리용"

#: scripts/makepkg.sh.in:910
msgid "  --holdver        Do not update VCS sources"
msgstr "  --holdver        VCS 원천화일들을 갱신하지 않음"

#: scripts/makepkg.sh.in:911
#, sh-printf-format
msgid "  --key <key>      Specify a key to use for %s signing instead of the default"
msgstr "  --key <열쇠>     기정값대신 %s 전자서명에 리용할 열쇠 지정"

#: scripts/makepkg.sh.in:912
msgid "  --noarchive      Do not create package archive"
msgstr "  --noarchive      패키지문서고를 생성하지 않음"

#: scripts/makepkg.sh.in:913
#, sh-printf-format
msgid "  --nocheck        Do not run the %s function in the %s"
msgstr "  --nocheck        %2$s안의 %1$s 함수를 실행하지 않음"

#: scripts/makepkg.sh.in:914
#, sh-printf-format
msgid "  --noprepare      Do not run the %s function in the %s"
msgstr "  --noprepare      %2$s안의 %1$s 함수를 실행하지 않음"

#: scripts/makepkg.sh.in:915
msgid "  --nosign         Do not create a signature for the package"
msgstr "  --nosign         패키지에 대한 전자서명을 생성하지 않음"

#: scripts/makepkg.sh.in:916
msgid "  --packagelist    Only list package filepaths that would be produced"
msgstr "  --packagelist    생성될 패키지화일경로목록만 현시"

#: scripts/makepkg.sh.in:917
msgid "  --printsrcinfo   Print the generated SRCINFO and exit"
msgstr "  --printsrcinfo   생성된 SRCINFO를 출력하고 종료"

#: scripts/makepkg.sh.in:918
#, sh-printf-format
msgid "  --sign           Sign the resulting package with %s"
msgstr "  --sign           결과패키지를 %s(으)로 전자서명"

#: scripts/makepkg.sh.in:919
msgid "  --skipchecksums  Do not verify checksums of the source files"
msgstr "  --skipchecksums  원천화일들의 검사합을 검증하지 않음"

#: scripts/makepkg.sh.in:920
msgid "  --skipinteg      Do not perform any verification checks on source files"
msgstr "  --skipinteg      원천화일들에 대해 어떠한 검증도 수행하지 않음"

#: scripts/makepkg.sh.in:921
msgid "  --skippgpcheck   Do not verify source files with PGP signatures"
msgstr "  --skippgpcheck   원천화일들을 PGP 전자서명으로 검증하지 않음"

#: scripts/makepkg.sh.in:922
msgid "  --verifysource   Download source files (if needed) and perform integrity checks"
msgstr "  --verifysource   (필요한 경우) 원천화일들을 내리적재하고 완전성검사 수행"

#: scripts/makepkg.sh.in:924
#, sh-printf-format
msgid "These options can be passed to %s:"
msgstr "이 선택항목들은 %s에 전달될수 있습니다:"

#: scripts/makepkg.sh.in:926
msgid "  --asdeps         Install packages as non-explicitly installed"
msgstr "  --asdeps         패키지들을 비명시적으로 설치된것으로 취급하여 설치"

#: scripts/makepkg.sh.in:927
msgid "  --needed         Do not reinstall the targets that are already up to date"
msgstr "  --needed         이미 최신판인 대상들을 재설치하지 않음"

#: scripts/makepkg.sh.in:928
msgid "  --noconfirm      Do not ask for confirmation when resolving dependencies"
msgstr "  --noconfirm      의존성들을 해결할 때 확인을 요구하지 않음"

#: scripts/makepkg.sh.in:929
msgid "  --noprogressbar  Do not show a progress bar when downloading files"
msgstr "  --noprogressbar  화일들을 내리적재할 때 진행상태를 현시하지 않음"

#: scripts/makepkg.sh.in:931
#, sh-printf-format
msgid "If %s is not specified, %s will look for '%s'"
msgstr "%s가 지정되지 않으면, %s는 '%s'를 찾을것입니다"

#: scripts/makepkg.sh.in:940 scripts/pacman-db-upgrade.sh.in:57
#: scripts/pacman-key.sh.in:99 scripts/repo-add.sh.in:107
msgid "This is free software; see the source for copying conditions.\\nThere is NO WARRANTY, to the extent permitted by law.\\n"
msgstr "이것은 자유소프트웨어입니다; 복사조건에 대해서는 원천을 보십시오.\\n법이 허용하는 한도내에서 어떠한 담보도 하지 않습니다.\\n"

#: scripts/makepkg.sh.in:1049 scripts/repo-add.sh.in:627
#, sh-printf-format
msgid "%s signal caught. Exiting..."
msgstr "%s 신호가 포착되였습니다. 종료하는중..."

#: scripts/makepkg.sh.in:1119
#, sh-printf-format
msgid "Running %s as root is not allowed as it can cause permanent,\\ncatastrophic damage to your system."
msgstr "%s를 최고관리자권한으로 실행하는것은 허용되지 않으며, 당신의 체계에 영구적이고\\n파괴적인 손상을 초래할수 있습니다."

#: scripts/makepkg.sh.in:1125
#, sh-printf-format
msgid "Do not use the %s option. This option is only for internal use by %s."
msgstr "%s 선택항목을 리용하지 마십시오. 이 항목은 %s의 내부적인 리용만을 위한것입니다."

#: scripts/makepkg.sh.in:1140
#, sh-printf-format
msgid "%s does not exist."
msgstr "%s가 존재하지 않습니다."

#: scripts/makepkg.sh.in:1145
#, sh-printf-format
msgid "%s contains %s characters and cannot be sourced."
msgstr "%s에 %s 문자가 포함되여있어 원천으로 리용할수 없습니다."

#: scripts/makepkg.sh.in:1150
#, sh-printf-format
msgid "%s must be in the current working directory."
msgstr "%s는 현재 작업등록부에 있어야 합니다."

#: scripts/makepkg.sh.in:1246 scripts/makepkg.sh.in:1261
#, sh-printf-format
msgid "Leaving %s environment."
msgstr "%s 환경에서 나가는중."

#: scripts/makepkg.sh.in:1273
#, sh-printf-format
msgid "The key %s does not exist in your keyring."
msgstr "당신의 열쇠모임에 열쇠 %s가 존재하지 않습니다."

#: scripts/makepkg.sh.in:1275 scripts/repo-add.sh.in:151
msgid "There is no key in your keyring."
msgstr "당신의 열쇠모임에 열쇠가 없습니다."

#: scripts/makepkg.sh.in:1281
#, sh-printf-format
msgid "Making package: %s"
msgstr "패키지구축중: %s"

#: scripts/makepkg.sh.in:1287
#, sh-printf-format
msgid "A source package has already been built. (use %s to overwrite)"
msgstr "원천패키지가 이미 구축되였습니다. (덧쓰려면 %s를 리용하십시오)"

#: scripts/makepkg.sh.in:1307
msgid "Signing package..."
msgstr "패키지에 전자서명하는중..."

#: scripts/makepkg.sh.in:1311
#, sh-printf-format
msgid "Source package created: %s"
msgstr "원천패키지가 생성되였습니다: %s"

#: scripts/makepkg.sh.in:1317
msgid "Skipping dependency checks."
